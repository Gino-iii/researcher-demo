# ===== LLM（OpenAI 兼容接口）=====
# 走 openai SDK + 自定义 base_url，可对接 DeepSeek / Qwen(DashScope) / Kimi / 本地 vLLM 等。
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.deepseek.com/v1

# 双模型分工：便宜的做子查询/摘要，贵的写最终报告。单模型提供商两个填一样即可。
FAST_LLM=deepseek-chat
SMART_LLM=deepseek-chat
TEMPERATURE=0.4

# ===== Embedding（M6 上下文压缩用；与 chat 分开配，见计划坑 10）=====
# DeepSeek 没有 embedding 端点。留空则 M6 自动降级为"截断丐版"。
# 有 embedding 的提供商示例（阿里 DashScope 兼容模式）：
#   EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   EMBEDDING_API_KEY=sk-xxxx
#   EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=

# ===== 搜索检索器 =====
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxx

# ===== 研究行为参数（一般用默认即可，调试期可调小省钱）=====
MAX_SEARCH_RESULTS_PER_QUERY=5   # 每个查询取几条搜索结果
MAX_ITERATIONS=3                 # 生成几个子查询（调试期可临时设 2）
TOTAL_WORDS=1200                 # 报告目标字数下限
LANGUAGE=chinese                 # 报告语言
VERBOSE=true                     # 是否打印过程日志
